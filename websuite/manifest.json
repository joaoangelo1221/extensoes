{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "2.0.0",
  "default_locale": "pt_BR",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "contextMenus",
    "notifications",
    "alarms",
    "scripting",
    "browsingData"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "prev-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Comma"
      },
      "description": "__MSG_commandPrevTab__"
    },
    "next-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period"
      },
      "description": "__MSG_commandNextTab__"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["modules/privacy/content/privacy-content.js"],
      "css": ["modules/privacy/content/privacy-content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
